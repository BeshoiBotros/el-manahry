<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Factory Tree View -->
    <record id="view_office_factory_tree" model="ir.ui.view">
        <field name="name">office.factory.tree</field>
        <field name="model">office.factory</field>
        <field name="arch" type="xml">
            <tree string="حسابات المصانع">
                <field name="name"/>
                <field name="factory_type"/>
                <field name="total_factory_invoices" sum="Total Invoices"/>
                <field name="total_factory_returns" sum="Total Returns"/>
                <field name="total_factory_payments" sum="Total Payments"/>
                <field name="total_factory_debt" sum="Total Remaining"/>
            </tree>
        </field>
    </record>

    <!-- Factory Form View -->
    <record id="view_office_factory_form" model="ir.ui.view">
        <field name="name">office.factory.form</field>
        <field name="model">office.factory</field>
        <field name="arch" type="xml">
            <form string="حساب المصنع">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="factory_type"/>
                        </group>
                        <group>
                            <field name="total_factory_invoices"/>
                            <field name="total_factory_returns"/>
                            <field name="total_factory_payments"/>
                            <field name="total_factory_debt" style="font-weight: bold; color: red;"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="التحصيلات">
                            <field name="payment_ids">
                                <tree editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="amount" sum="Total"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Factory Action -->
    <record id="action_office_factory" model="ir.actions.act_window">
        <field name="name">Factory Accounts (حسابات المصانع)</field>
        <field name="res_model">office.factory</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
