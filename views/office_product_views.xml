<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_office_product_form" model="ir.ui.view">
        <field name="name">office.product.form</field>
        <field name="model">office.product</field>
        <field name="arch" type="xml">
            <form string="Product">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Product Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="list_price"/>
                            <field name="factory_type"/>
                        </group>
                        <group>
                            <field name="profit_type"/>
                            <field name="profit_value"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_office_product_tree" model="ir.ui.view">
        <field name="name">office.product.tree</field>
        <field name="model">office.product</field>
        <field name="arch" type="xml">
            <tree string="Products">
                <field name="name"/>
                <field name="factory_type"/>
                <field name="list_price"/>
                <field name="profit_type"/>
                <field name="profit_value"/>
            </tree>
        </field>
    </record>

    <record id="action_office_product" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">office.product</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
