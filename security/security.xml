<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.module.category" id="module_category_office_client_cards">
        <field name="name">Office Client Cards</field>
        <field name="description">Helps you manage office clients and debts.</field>
        <field name="sequence">20</field>
    </record>

    <!-- Groups -->
    <record id="group_office_client_user" model="res.groups">
        <field name="name">Office Client / User</field>
        <field name="category_id" ref="module_category_office_client_cards"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_office_client_manager" model="res.groups">
        <field name="name">Office Client / Manager</field>
        <field name="category_id" ref="module_category_office_client_cards"/>
        <field name="implied_ids" eval="[(4, ref('office_client_cards.group_office_client_user'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="rule_office_client_user" model="ir.rule">
        <field name="name">Office Client User Own Clients</field>
        <field name="model_id" ref="model_office_client"/>
        <!-- <field name="domain_force">[('user_id', '=', user.id)]</field> Removed because office.client does not have a user_id field -->
        <field name="groups" eval="[(4, ref('group_office_client_user'))]"/>
    </record>

    <record id="rule_office_client_manager" model="ir.rule">
        <field name="name">Office Client Manager All Clients</field>
        <field name="model_id" ref="model_office_client"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_office_client_manager'))]"/>
    </record>

    <record id="rule_office_client_transaction_user" model="ir.rule">
        <field name="name">Office Client Transaction User Own</field>
        <field name="model_id" ref="model_office_client_transaction"/>
        <field name="domain_force">[('client_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_office_client_user'))]"/>
    </record>

    <record id="rule_office_client_transaction_manager" model="ir.rule">
        <field name="name">Office Client Transaction Manager All</field>
        <field name="model_id" ref="model_office_client_transaction"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_office_client_manager'))]"/>
    </record>
</odoo>
